@page "/"
@inject IStringLocalizer<App> L
@inject NavigationManager NavigationManager
@inject HttpClient Http
@implements IAsyncDisposable

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show mx-auto" style="max-width:900px;" role="alert" aria-live="polite">
        <strong>@L["Success"]:</strong> @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (registrationOpen)
{
    <!-- Hero Banner -->
    <section class="page-hero" aria-label="@L["Home_Hero_Aria"]">
        <div class="page-hero-overlay" aria-hidden="true"></div>
        <div class="container position-relative" style="z-index:1;">
            <div class="row align-items-center justify-content-center text-center py-5">
                <div class="col-lg-8">
                    <span class="badge page-hero-badge mb-3">
                        <span aria-hidden="true">&#9917;</span> @(seasonYear.HasValue ? seasonYear.Value.ToString() : "") Season
                    </span>
                    <h1 class="display-4 fw-bold text-white mb-3">@L["Title"]</h1>
                    <p class="lead page-hero-subtitle mb-4" style="font-size:1.15rem;">@L["Home_Intro"]</p>
                    <div class="d-flex flex-wrap gap-3 justify-content-center">
                        <NavLink class="btn page-btn-cta btn-lg px-4"
                                 href="/register"
                                 aria-label="@L["Register_Button"]">
                            @L["Register_Button"]
                        </NavLink>
                        <NavLink class="btn page-btn-cta-outline btn-lg px-4"
                                 href="/volunteer"
                                 aria-label="@L["RegisterVolunteer_Button"]">
                            @L["RegisterVolunteer_Button"]
                        </NavLink>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="container" style="max-width:960px;">

        <!-- Season Highlights -->
        <section class="my-5" role="region" aria-label="@L["Home_SeasonHighlights_Aria"]">
            <h2 class="page-section-title">
                @(seasonYear.HasValue ? string.Format(L["Home_SeasonHighlights_Title"], seasonYear.Value) : L["Home_SeasonHighlights_Title_NoYear"])
            </h2>
            <div class="row g-3">
                <div class="col-sm-6 col-lg-4">
                    <div class="page-stat-card">
                        <div class="page-stat-icon" aria-hidden="true">&#127874;</div>
                        <div>
                            <div class="page-stat-label">@L["Home_Ages_Label"]</div>
                            <div class="page-stat-value">@string.Format(L["Home_Ages_Value"], oldestBirthYear, preschoolYear)</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="page-stat-card">
                        <div class="page-stat-icon" aria-hidden="true">&#128176;</div>
                        <div>
                            <div class="page-stat-label">@L["Home_Fee_Label"]</div>
                            <div class="page-stat-value">@L["Home_Fee_Value"]</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="page-stat-card">
                        <div class="page-stat-icon" aria-hidden="true">&#128118;</div>
                        <div>
                            <div class="page-stat-label">@string.Format(L["Home_PreschoolNote_Label"], preschoolYear)</div>
                            <div class="page-stat-value">@L["Home_PreschoolNote_Value"]</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-6">
                    <div class="page-stat-card">
                        <div class="page-stat-icon" aria-hidden="true">&#129491;</div>
                        <div>
                            <div class="page-stat-label">@L["Home_Coach_Label"]</div>
                            <div class="page-stat-value">@L["Home_Coach_Value"]</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-6">
                    <div class="page-stat-card">
                        <div class="page-stat-icon" aria-hidden="true">&#127937;</div>
                        <div>
                            <div class="page-stat-label">@L["Home_Referee_Label"]</div>
                            <div class="page-stat-value">@L["Home_Referee_Value"]</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Registration Details -->
        <section class="mb-5">
            <div class="page-card">
                <div class="page-card-header">
                    <h2 class="h5 mb-0">@L["Home_RegistrationInfo_Title"]</h2>
                </div>
                <div class="page-card-body">
                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_RegNights_Label"]</span>
                        <span class="page-detail-value">@L["Home_RegNights_Value"]</span>
                    </div>
                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_Time_Label"]</span>
                        <span class="page-detail-value">@L["Home_Time_Value"]</span>
                    </div>
                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_Location_Label"]</span>
                        <span class="page-detail-value">@L["Home_Location_Value"]</span>
                    </div>
                    <div class="page-detail-row border-0">
                        <span class="page-detail-label">@L["Home_Payment_Label"]</span>
                        <span class="page-detail-value">@L["Home_Payment_Value"]</span>
                    </div>

                    <div class="page-callout page-callout-warning mt-3" role="note" aria-label="@L["Home_ImportantDeadlines_Aria"]">
                        <h3 class="h6 fw-bold mb-2"><span aria-hidden="true">&#9888;&#65039;</span> @L["Home_ImportantDeadlines_Title"]</h3>
                        <ul class="mb-0 ps-3">
                            <li>@L["Home_LateFee_Note"]</li>
                            @if (registrationCloseDate.HasValue)
                            {
                                <li>@string.Format(L["Home_Deadline_Note"], registrationCloseDate.Value.ToString(L["Home_DateFormat_DeadlineDate"]))</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- General Season Info -->
        <section class="mb-5">
            <div class="page-card">
                <div class="page-card-header">
                    <h2 class="h5 mb-0">@L["Home_GeneralInfo_Title"]</h2>
                </div>
                <div class="page-card-body">

                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_Email_Label"]</span>
                        <span class="page-detail-value">
                            <a href="mailto:socceroptimistecass@gmail.com">socceroptimistecass@gmail.com</a>
                        </span>
                    </div>

                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_Facebook_Label"]</span>
                        <span class="page-detail-value">
                            <a href="https://facebook.com/socceroptimistecass"
                               target="_blank"
                               rel="noopener"
                               aria-label="@L["Home_Facebook_Value"]">
                                Optimiste de Casselman
                            </a>
                            <span class="d-block small text-muted">@L["Home_Facebook_Value"]</span>
                        </span>
                    </div>

                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_SeasonDuration_Label"]</span>
                        <span class="page-detail-value">
                            @if (seasonStartDate.HasValue && seasonEndDate.HasValue)
                            {
                                @string.Format(L["Home_SeasonDuration_Value"], seasonStartDate.Value.ToString(L["Home_DateFormat_StartDate"]), seasonEndDate.Value.ToString(L["Home_DateFormat_EndDate"]))
                            }
                            else
                            {
                                @L["Home_SeasonDuration_Value_Default"]
                            }
                        </span>
                    </div>

                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_GameLocation_Label"]</span>
                        <span class="page-detail-value">
                            @L["Home_GameLocation_School"]<br />
                            @L["Home_GameLocation_Address"]
                            <span class="d-block text-muted small">@L["Home_GameLocation_Note"]</span>
                        </span>
                    </div>

                    <div class="page-detail-row">
                        <div class="page-detail-label">@L["Home_GameTime_Label"]</div>
                        <div class="page-detail-value">
                            <ul class="mb-0 ps-3">
                                <li>@string.Format(L["Home_GameTime_2022"], preschoolYear)</li>
                                <li>@L["Home_GameTime_Other1"]</li>
                                <li>@L["Home_GameTime_Other2"]</li>
                            </ul>
                        </div>
                    </div>

                    <div class="page-detail-row border-0">
                        <div class="page-detail-label">@L["Home_MandatoryEquipment_Label"]</div>
                        <div class="page-detail-value">
                            <ul class="mb-0 ps-3">
                                <li>@string.Format(L["Home_MandatoryEquipment_ShinPads"], shinPadYear)</li>
                                <li>@L["Home_MandatoryEquipment_Shoes"]</li>
                            </ul>
                        </div>
                    </div>

                    <div class="page-callout page-callout-danger mt-3" role="note" aria-label="@L["Home_Cancellation_Aria"]">
                        <h3 class="h6 fw-bold mb-2"><span aria-hidden="true">&#128683;</span> @L["Home_Cancellation_Title"]</h3>
                        <p class="mb-0">@L["Home_Cancellation_Note"]</p>
                    </div>
                </div>
            </div>
        </section>

    </div>
}
else
{
    <!-- Off-season landing page -->
    <section class="page-hero" aria-label="@L["Home_Hero_Aria"]">
        <div class="page-hero-overlay" aria-hidden="true"></div>
        <div class="container position-relative" style="z-index:1;">
            <div class="row align-items-center justify-content-center text-center py-5">
                <div class="col-lg-8">
                    <span class="badge page-hero-badge mb-3">
                        <span aria-hidden="true">&#9917;</span> @L["Title"]
                    </span>
                    <h1 class="display-4 fw-bold text-white mb-3">@L["Title"]</h1>
                    <p class="lead page-hero-subtitle mb-4" style="font-size:1.15rem;">@L["Home_Intro"]</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container" style="max-width:960px;">

        <section class="my-5">
            <div class="page-callout page-callout-info">
                <h2 class="h5 fw-bold mb-2"><span aria-hidden="true">&#128226;</span> @L["Home_OffSeason_Title"]</h2>
                <p class="mb-0">@L["Home_OffSeason_Message"]</p>
            </div>
        </section>

        <section class="mb-5">
            <div class="page-card">
                <div class="page-card-header">
                    <h2 class="h5 mb-0">@L["Home_OffSeason_Contact_Title"]</h2>
                </div>
                <div class="page-card-body">
                    <div class="page-detail-row">
                        <span class="page-detail-label">@L["Home_Email_Label"]</span>
                        <span class="page-detail-value">
                            <a href="mailto:socceroptimistecass@gmail.com">socceroptimistecass@gmail.com</a>
                        </span>
                    </div>
                    <div class="page-detail-row border-0">
                        <span class="page-detail-label">@L["Home_Facebook_Label"]</span>
                        <span class="page-detail-value">
                            <a href="https://facebook.com/socceroptimistecass"
                               target="_blank"
                               rel="noopener"
                               aria-label="@L["Home_Facebook_Value"]">
                                Optimiste de Casselman
                            </a>
                            <span class="d-block small text-muted">@L["Home_Facebook_Value"]</span>
                        </span>
                    </div>
                </div>
            </div>
        </section>

    </div>
}

@code {
    private bool registrationOpen = true;
    private int? seasonYear;
    private DateTime? seasonStartDate;
    private DateTime? seasonEndDate;
    private DateTime? registrationCloseDate;
    private string? successMessage;
    private CancellationTokenSource? dismissalCts;

    private int referenceYear => seasonYear ?? DateTime.Now.Year;
    private int preschoolYear => referenceYear - 4;
    private int oldestBirthYear => referenceYear - 14;
    private int shinPadYear => referenceYear - 5;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<RegistrationStatusResponse>("/api/registration/status");
            registrationOpen = result?.IsOpen ?? false;
            seasonYear = result?.SeasonYear;
            seasonStartDate = result?.StartDate;
            seasonEndDate = result?.EndDate;
            registrationCloseDate = result?.RegistrationCloseDate;
        }
        catch
        {
            registrationOpen = false;
        }
    }

    private record RegistrationStatusResponse(bool IsOpen, int? SeasonYear, DateTime? StartDate, DateTime? EndDate, DateTime? RegistrationCloseDate);

    protected override void OnInitialized()
    {
        var uri = NavigationManager.Uri;
        var query = System.Web.HttpUtility.ParseQueryString(new UriBuilder(uri).Query);
        successMessage = query["success"];

        if (!string.IsNullOrWhiteSpace(successMessage))
        {
            dismissalCts = new CancellationTokenSource();
            _ = DismissMessageAsync();
        }
    }

    private async Task DismissMessageAsync()
    {
        if (dismissalCts == null)
            return;

        try
        {
            await Task.Delay(5000, dismissalCts.Token);
            successMessage = null;
            StateHasChanged();

            NavigationManager.NavigateTo("/");
        }
        catch (OperationCanceledException)
        {
        }
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        dismissalCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
