@page "/volunteer"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@using OptimistClub_SoccerRegistration.Services
@using OptimistClub_SoccerRegistration.Data.Models
@inject IRegistrationService RegistrationService
@inject IStringLocalizer<OptimistClub_SoccerRegistration.SharedResource> L
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<!-- Hero Banner -->
<section class="page-hero" aria-label="@L["VolunteerInfo"]">
<div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center text-center py-4">
            <div class="col-lg-8">
                <span class="badge page-hero-badge mb-3">
                    <span aria-hidden="true">&#9917;</span> @(seasonYear.HasValue ? seasonYear.Value.ToString() : "")
                </span>
                <h1 class="page-hero-title">@L["VolunteerInfo"] @(seasonYear.HasValue ? seasonYear.Value : "")</h1>
                <p class="page-hero-subtitle">@L["VolunteerPageNotice"]</p>
            </div>
        </div>
    </div>
</section>

<div class="page-form-container mt-4">

@if (registrationCompleted)
{
    <div class="page-callout page-callout-success mb-4" role="alert">
        <h3 class="h6 fw-bold mb-2">✅ @successMessage</h3>
    </div>

    <button class="btn btn-primary" @onclick="RegisterAnother">@L["RegisterAnotherVolunteer"]</button>
}
else if (!registrationOpen)
{
    <div class="page-callout page-callout-warning" role="alert">
        <strong>@L["RegistrationClosed"]</strong>
    </div>
}
else
{
    <EditForm EditContext="editContext" OnSubmit="HandleSubmit">

        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["VolunteerInfo"] @(seasonYear.HasValue ? seasonYear.Value : "")</h2>
            </div>
            <div class="page-card-body">

                @if (showMandatoryFieldsWarning && validationErrors.Any())
                {
                    <div class="page-callout page-callout-danger mb-4" role="alert" aria-live="assertive">
                        <div class="d-flex align-items-start">
                            <div>
                                <strong>@L["MandatoryFields"]</strong>
                                <ul class="mb-0 mt-2 ps-3">
                                    @foreach (var error in validationErrors)
                                    {
                                        <li>@error</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="page-callout page-callout-danger mb-4" role="alert">
                        <strong>Error:</strong> @errorMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="page-callout page-callout-success mb-4" role="alert">
                        <strong>Success:</strong> @successMessage
                    </div>
                }

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="volunteerFirstName">@L["FirstName"] <span class="text-danger">*</span></label>
                        <input id="volunteerFirstName"
                               name="volunteerFirstName"
                               class="form-control"
                               autocomplete="given-name"
                               @bind="model.FirstName" />
                        <ValidationMessage For="@(() => model.FirstName)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="volunteerLastName">@L["LastName"] <span class="text-danger">*</span></label>
                        <input id="volunteerLastName"
                               name="volunteerLastName"
                               class="form-control"
                               autocomplete="family-name"
                               @bind="model.LastName" />
                        <ValidationMessage For="@(() => model.LastName)" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="volunteerPhone">@L["Phone"] <span class="text-danger">*</span></label>
                    <input id="volunteerPhone"
                           name="volunteerPhone"
                           class="form-control"
                           autocomplete="tel"
                           inputmode="tel"
                           @bind="model.Phone" />
                    <ValidationMessage For="@(() => model.Phone)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="volunteerEmail">@L["Email"] <span class="text-danger">*</span></label>
                    <input id="volunteerEmail"
                           name="volunteerEmail"
                           type="email"
                           class="form-control"
                           autocomplete="email"
                           inputmode="email"
                           @bind="model.Email" />
                    <ValidationMessage For="@(() => model.Email)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="volunteerRole">@L["VolunteerRole"] <span class="text-danger">*</span></label>
                    <select id="volunteerRole"
                            name="volunteerRole"
                            class="form-select"
                            @bind="model.Role">
                        <option value="">@L["Select"]</option>
                        <option value="Coach">@L["Coach"]</option>
                        <option value="Referee">@L["Referee"]</option>
                    </select>
                    <ValidationMessage For="@(() => model.Role)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="criminalCheck">@L["CriminalCheck"] <span class="text-danger">*</span></label>
                    <select id="criminalCheck"
                            name="criminalCheck"
                            class="form-select"
                            @bind="model.CriminalCheck">
                        <option value="">@L["Select"]</option>
                        <option value="Yes">@L["Yes"]</option>
                        <option value="No">@L["No"]</option>
                    </select>
                    <ValidationMessage For="@(() => model.CriminalCheck)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="volunteerShirtSize">@L["VolunteerShirtSize"] <span class="text-danger">*</span></label>
                    <select id="volunteerShirtSize"
                            name="volunteerShirtSize"
                            class="form-select"
                            @bind="model.ShirtSize">
                        <option value="">@L["Select"]</option>
                        <option value="AdultS">@L["AdultS"]</option>
                        <option value="AdultM">@L["AdultM"]</option>
                        <option value="AdultL">@L["AdultL"]</option>
                        <option value="AdultXL">@L["AdultXL"]</option>
                        <option value="AdultXXL">@L["AdultXXL"]</option>
                    </select>
                    <ValidationMessage For="@(() => model.ShirtSize)" />
                </div>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting" aria-busy="@isSubmitting" aria-label="@(isSubmitting ? L["Saving"] : L["Submit"])">
                    @if (isSubmitting)
                    {
                        <span aria-hidden="true">@L["Saving"]</span>
                    }
                    else
                    {
                        @L["Submit"]
                    }
                </button>
            </div>
        </div>
    </EditForm>
}

</div>

@code {
private bool isSubmitting;
private bool showMandatoryFieldsWarning;
private bool registrationCompleted;
private string? successMessage;
private string? errorMessage;
private List<string> validationErrors = new();

private VolunteerPageModel model = new();
private EditContext editContext = null!;
private ValidationMessageStore messageStore = null!;

protected override void OnInitialized()
{
    model = new VolunteerPageModel();
    editContext = new EditContext(model);
    messageStore = new ValidationMessageStore(editContext);
}

private void RegisterAnother()
{
    registrationCompleted = false;
    successMessage = null;
    errorMessage = null;
    showMandatoryFieldsWarning = false;
    validationErrors.Clear();
    model = new VolunteerPageModel();
    editContext = new EditContext(model);
    messageStore = new ValidationMessageStore(editContext);
}

private bool ValidateModel()
{
    var context = new ValidationContext(model);
    context.Items["Localizer"] = L;
    var results = new List<ValidationResult>();
    Validator.TryValidateObject(model, context, results, true);

    messageStore.Clear();

    foreach (var result in results)
    {
        foreach (var memberName in result.MemberNames)
        {
            messageStore.Add(editContext.Field(memberName), result.ErrorMessage ?? string.Empty);
        }
    }

    editContext.NotifyValidationStateChanged();
    validationErrors = results.Select(r => r.ErrorMessage ?? string.Empty).ToList();

    return results.Count == 0;
}

private async Task HandleSubmit()
{
    if (!ValidateModel())
    {
        showMandatoryFieldsWarning = true;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        return;
    }

    await Submit();
}

private async Task Submit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;
            successMessage = null;
            showMandatoryFieldsWarning = false;

            var parent = new Parent
            {
                FirstName = model.FirstName ?? string.Empty,
                LastName = model.LastName ?? string.Empty,
                PhoneNumber = model.Phone,
                Email = model.Email
            };
            await RegistrationService.CreateParentAsync(parent);

            var volunteer = new Volunteer
            {
                ParentId = parent.ParentId,
                FirstName = model.FirstName ?? string.Empty,
                LastName = model.LastName ?? string.Empty,
                Role = model.Role,
                ShirtSize = model.ShirtSize,
                CriminalCheckCompleted = model.CriminalCheck == "Yes"
            };
            await RegistrationService.CreateVolunteerAsync(volunteer);

            successMessage = L["VolunteerRegistrationComplete"];
            registrationCompleted = true;
            model = new VolunteerPageModel();

            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException?.InnerException?.Message
                ?? ex.InnerException?.Message
                ?? ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class VolunteerPageModel : IValidatableObject
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Role { get; set; }
        public string? CriminalCheck { get; set; }
        public string? ShirtSize { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            var localizer = validationContext.Items.ContainsKey("Localizer")
                ? validationContext.Items["Localizer"] as IStringLocalizer<SharedResource>
                : null;

            if (string.IsNullOrWhiteSpace(FirstName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_FirstNameRequired"] ?? "First name is required.",
                    new[] { nameof(FirstName) });
            }

            if (string.IsNullOrWhiteSpace(LastName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_LastNameRequired"] ?? "Last name is required.",
                    new[] { nameof(LastName) });
            }

            if (string.IsNullOrWhiteSpace(Phone))
            {
                yield return new ValidationResult(
                    localizer?["Validation_PhoneRequired"] ?? "Phone number is required.",
                    new[] { nameof(Phone) });
            }

            if (string.IsNullOrWhiteSpace(Email))
            {
                yield return new ValidationResult(
                    localizer?["Validation_EmailRequired"] ?? "Email is required.",
                    new[] { nameof(Email) });
            }
            else if (!Email.Contains("@"))
            {
                yield return new ValidationResult(
                    localizer?["Validation_EmailInvalid"] ?? "Enter a valid email address.",
                    new[] { nameof(Email) });
            }

            if (string.IsNullOrWhiteSpace(Role))
            {
                yield return new ValidationResult(
                    localizer?["Validation_VolunteerRoleRequired"] ?? "Volunteer role is required.",
                    new[] { nameof(Role) });
            }

            if (string.IsNullOrWhiteSpace(CriminalCheck))
            {
                yield return new ValidationResult(
                    localizer?["Validation_CriminalCheckRequired"] ?? "Criminal check selection is required.",
                    new[] { nameof(CriminalCheck) });
            }

            if (string.IsNullOrWhiteSpace(ShirtSize))
            {
                yield return new ValidationResult(
                    localizer?["Validation_VolunteerShirtSizeRequired"] ?? "Volunteer shirt size is required.",
                    new[] { nameof(ShirtSize) });
            }
        }
    }

    private bool registrationOpen;
    private int? seasonYear;

    protected override async Task OnInitializedAsync()
    {
        var activePeriod = await RegistrationService.GetActiveRegistrationPeriodAsync();
        registrationOpen = activePeriod != null;
        seasonYear = activePeriod?.SeasonYear;
    }
}
