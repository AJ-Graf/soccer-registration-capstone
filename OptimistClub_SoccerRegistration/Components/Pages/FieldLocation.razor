@page "/field-location"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OptimistClub_SoccerRegistration.SharedResource> L

<!-- Hero Banner -->
<section class="page-hero" aria-label="@L["FieldLocation"]">
<div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center text-center py-4">
            <div class="col-lg-8">
                <span class="badge page-hero-badge mb-3" aria-hidden="true">
                    &#128205;
                </span>
                <h1 class="page-hero-title">@L["FieldLocation"]</h1>
                <p class="page-hero-subtitle">@L["FieldLocationAddress"]</p>
            </div>
        </div>
    </div>
</section>

<div class="container" style="max-width:960px;">
    <section class="my-4">
        <div class="page-card">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["SelectField"]</h2>
            </div>
            <div class="page-card-body">
                <div class="field-selector d-flex flex-wrap gap-2 mb-3">
                    @for (int i = 1; i <= 6; i++)
                    {
                        var fieldNum = i;
                        <button type="button"
                                class="field-btn @(selectedField == fieldNum ? "active" : "")"
                                aria-label="@($"{L["Field"]} {fieldNum}")"
                                aria-pressed="@(selectedField == fieldNum ? "true" : "false")"
                                @onclick="() => SelectField(fieldNum)">
                            @fieldNum
                        </button>
                    }
                </div>

                <div class="map-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d1404!2d-75.0865!3d45.318!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1sen!2sca"
                            title="@L["FieldLocation"] - Google Maps"
                            aria-label="@L["FieldLocation"] - Google Maps"
                            style="border:0; width:100%; height:100%;"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                    <div class="map-overlay"></div>

                    @if (selectedField.HasValue)
                    {
                        <div class="field-marker" style="@GetMarkerStyle(selectedField.Value)">
                            <span>@L["Field"] @selectedField.Value</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private int? selectedField;

    private void SelectField(int fieldNum)
    {
        selectedField = selectedField == fieldNum ? null : fieldNum;
    }

    private string GetMarkerStyle(int fieldNum)
    {
        return fieldNum switch
        {
            1 => "top: 20%; left: 10%;",
            2 => "top: 20%; left: 35%;",
            3 => "top: 20%; left: 60%;",
            4 => "top: 55%; left: 10%;",
            5 => "top: 55%; left: 35%;",
            6 => "top: 55%; left: 60%;",
            _ => "top: 50%; left: 50%;"
        };
    }
}
