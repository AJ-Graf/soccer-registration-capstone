@page "/admin/seasons"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using OptimistClub_SoccerRegistration.Data
@using OptimistClub_SoccerRegistration.Data.Models
@attribute [Authorize(Roles = "Admin")]
@inject ApplicationDbContext Context

<h2>Season Registration</h2>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">@(editingPeriod != null ? "Edit Period" : "Create New Period")</div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-2 mb-2">
                <label class="form-label">Season Year</label>
                <input type="number" class="form-control" @bind="formYear" />
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">Start Date</label>
                <input type="date" class="form-control" @bind="formStart" />
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">End Date</label>
                <input type="date" class="form-control" @bind="formEnd" />
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Active</label>
                <select class="form-select" @bind="formActiveStr">
                    <option value="">Select</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
        </div>
        <div class="row mt-2">
            <div class="col-md-3 mb-2">
                <label class="form-label">Registration Opens</label>
                <input type="date" class="form-control" @bind="formRegOpen" />
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">Registration Closes</label>
                <input type="date" class="form-control" @bind="formRegClose" />
            </div>
            <div class="col-md-2 mb-2 d-flex align-items-end">
                <button class="btn btn-primary me-2" @onclick="SavePeriod">Save</button>
                @if (editingPeriod != null)
                {
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </div>
    </div>
</div>

@if (periods == null)
{
    <p>Loading season registration data</p>
}
else if (periods.Count == 0)
{
    <p>There isn't any season registration data</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Season Year</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Registration Opens</th>
                <th>Registration Closes</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in periods)
            {
                <tr>
                    <td>@p.SeasonYear</td>
                    <td>@p.StartDate.ToShortDateString()</td>
                    <td>@p.EndDate.ToShortDateString()</td>
                    <td>@(p.RegistrationOpenDate.HasValue ? p.RegistrationOpenDate.Value.ToShortDateString() : "—")</td>
                    <td>@(p.RegistrationCloseDate.HasValue ? p.RegistrationCloseDate.Value.ToShortDateString() : "—")</td>
                    <td>
                        @if (p.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditPeriod(p)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePeriod(p.PeriodId)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RegistrationPeriod>? periods;
    private RegistrationPeriod? editingPeriod;

    private int? formYear;
    private DateTime? formStart;
    private DateTime? formEnd;
    private DateTime? formRegOpen;
    private DateTime? formRegClose;
    private string formActiveStr = "";
    private bool formActive => string.Equals(formActiveStr, "true", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        periods = await Context.RegistrationPeriods
            .OrderByDescending(p => p.SeasonYear)
            .ToListAsync();
    }

    private string? errorMessage;

    private async Task SavePeriod()
    {
        errorMessage = null;

        if (!formYear.HasValue || !formStart.HasValue || !formEnd.HasValue || string.IsNullOrEmpty(formActiveStr))
        {
            errorMessage = "All fields are required.";
            return;
        }

        var duplicateExists = await Context.RegistrationPeriods
            .AnyAsync(p => p.SeasonYear == formYear.Value && (editingPeriod == null || p.PeriodId != editingPeriod.PeriodId));

        if (duplicateExists)
        {
            errorMessage = $"A registration period for the {formYear.Value} season already exists.";
            return;
        }

        if (formActive)
        {
            var otherActive = await Context.RegistrationPeriods
                .Where(p => p.IsActive && (editingPeriod == null || p.PeriodId != editingPeriod.PeriodId))
                .ToListAsync();
            foreach (var op in otherActive)
            {
                op.IsActive = false;
            }
        }

        if (formRegOpen.HasValue && formRegClose.HasValue && formRegOpen.Value > formRegClose.Value)
        {
            errorMessage = "Registration open date must be before the close date.";
            return;
        }

        if (editingPeriod != null)
        {
            editingPeriod.SeasonYear = formYear.Value;
            editingPeriod.StartDate = formStart.Value;
            editingPeriod.EndDate = formEnd.Value;
            editingPeriod.IsActive = formActive;
            editingPeriod.RegistrationOpenDate = formRegOpen;
            editingPeriod.RegistrationCloseDate = formRegClose;
            Context.RegistrationPeriods.Update(editingPeriod);
        }
        else
        {
            var newPeriod = new RegistrationPeriod
            {
                SeasonYear = formYear.Value,
                StartDate = formStart.Value,
                EndDate = formEnd.Value,
                IsActive = formActive,
                RegistrationOpenDate = formRegOpen,
                RegistrationCloseDate = formRegClose
            };
            Context.RegistrationPeriods.Add(newPeriod);
        }

        await Context.SaveChangesAsync();
        editingPeriod = null;
        ResetForm();
        await LoadData();
    }

    private void EditPeriod(RegistrationPeriod p)
    {
        editingPeriod = p;
        formYear = p.SeasonYear;
        formStart = p.StartDate;
        formEnd = p.EndDate;
        formRegOpen = p.RegistrationOpenDate;
        formRegClose = p.RegistrationCloseDate;
        formActiveStr = p.IsActive ? "true" : "false";
    }

    private void CancelEdit()
    {
        editingPeriod = null;
        ResetForm();
    }

    private void ResetForm()
    {
        formYear = null;
        formStart = null;
        formEnd = null;
        formRegOpen = null;
        formRegClose = null;
        formActiveStr = "";
    }

    private async Task DeletePeriod(int id)
    {
        var period = await Context.RegistrationPeriods.FindAsync(id);
        if (period != null)
        {
            Context.RegistrationPeriods.Remove(period);
            await Context.SaveChangesAsync();
            await LoadData();
        }
    }
}