@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@using OptimistClub_SoccerRegistration.Services
@using OptimistClub_SoccerRegistration.Data.Models
@inject IRegistrationService RegistrationService
@inject IStringLocalizer<OptimistClub_SoccerRegistration.SharedResource> L
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<!-- Hero Banner -->
<section class="page-hero" aria-label="@L["Title"]">
<div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center text-center py-4">
            <div class="col-lg-8">
                <span class="badge page-hero-badge mb-3">
                    <span aria-hidden="true">&#9917;</span> @(seasonYear.HasValue ? seasonYear.Value.ToString() : "")
                </span>
                <h1 class="page-hero-title">@L["Title"]</h1>
                <p class="page-hero-subtitle">@L["Intro"]</p>
            </div>
        </div>
    </div>
</section>

<div class="page-form-container mt-4">

@if (registrationCompleted)
{
    <div class="page-callout page-callout-success mb-4" role="alert">
        <h3 class="h6 fw-bold mb-2">✅ @successMessage</h3>
    </div>

    <div class="page-card mb-4">
        <div class="page-card-header">
            <h2 class="h5 mb-0">@L["PaymentTitle"]</h2>
        </div>
        <div class="page-card-body">
            <p>@L["PaymentInstructions_Intro"]</p>
            <ul class="mb-0 ps-3">
                <li>@L["PaymentInstructions_Cheque"]</li>
                <li>@L["PaymentInstructions_ETransfer"]</li>
                <li>@L["PaymentInstructions_Cash"]</li>
            </ul>
        </div>
    </div>

    <button class="btn btn-primary" @onclick="RegisterAnother">@L["RegisterAnotherPlayer"]</button>
}
else if (!registrationOpen)
{
    <div class="page-callout page-callout-warning" role="alert">
        <strong>@L["RegistrationClosed"]</strong>
    </div>
}
else
{

    <EditForm Model="model" OnValidSubmit="Submit" OnInvalidSubmit="HandleInvalidSubmit">
        <DataAnnotationsValidator />

        @if (showMandatoryFieldsWarning && validationErrors.Any())
        {
            <div class="page-callout page-callout-danger mb-4" role="alert" aria-live="assertive">
                <div class="d-flex align-items-start">
                    <div>
                        <strong>@L["MandatoryFields"]</strong>
                        <ul class="mb-0 mt-2 ps-3">
                            @foreach (var error in validationErrors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="page-callout page-callout-danger mb-4" role="alert">
                <strong>Error:</strong> @errorMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="page-callout page-callout-success mb-4" role="alert">
                <strong>Success:</strong> @successMessage
            </div>
        }


        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["PlayerInfo"]</h2>
            </div>
            <div class="page-card-body">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="playerFirstName">@L["FirstName"] <span class="text-danger">*</span></label>
                        <input id="playerFirstName"
                        name="playerFirstName"
                        class="form-control"
                        autocomplete="given-name"
                        @bind="model.Player.FirstName" />
                        <ValidationMessage For="@(() => model.Player.FirstName)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="playerLastName">@L["LastName"] <span class="text-danger">*</span></label>
                        <input id="playerLastName"
                        name="playerLastName"
                        class="form-control"
                        autocomplete="family-name"
                        @bind="model.Player.LastName" />
                        <ValidationMessage For="@(() => model.Player.LastName)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="playerGender">@L["Gender"] <span class="text-danger">*</span></label>
                        <select id="playerGender"
                        name="playerGender"
                        class="form-select"
                        @bind="model.Player.Gender">
                            <option value="">@L["Select"]</option>
                            <option value="Male">@L["Male"]</option>
                            <option value="Female">@L["Female"]</option>
                        </select>
                        <ValidationMessage For="@(() => model.Player.Gender)" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="playerTown">@L["Town"]</label>
                        <input id="playerTown"
                        name="playerTown"
                        class="form-control"
                        autocomplete="address-level2"
                        @bind="model.Player.Town" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="playerDob">@L["DateOfBirth"] <span class="text-danger">*</span></label>
                        <input id="playerDob"
                        name="playerDob"
                        type="date"
                        class="form-control"
                        @bind="model.Player.DateOfBirth"
                        @bind:format="yyyy-MM-dd" />
                        <ValidationMessage For="@(() => model.Player.DateOfBirth)" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="playerShirtSize">@L["ChildShirtSize"] <span class="text-danger">*</span></label>
                    <select id="playerShirtSize"
                    name="playerShirtSize"
                    class="form-select"
                    @bind="model.Player.ShirtSize">
                        <option value="">@L["Select"]</option>
                        <option value="ChildXS">@L["ChildXS"]</option>
                        <option value="ChildS">@L["ChildS"]</option>
                        <option value="ChildM">@L["ChildM"]</option>
                        <option value="ChildL">@L["ChildL"]</option>
                    </select>
                    <ValidationMessage For="@(() => model.Player.ShirtSize)" />
                </div>

                <div class="page-callout page-callout-warning mt-3">
                    @(seasonYear.HasValue ? string.Format(L["ImportantBirthYear"], seasonYear.Value - 4) : L["Important2022"])
                </div>

            </div>
        </div>

        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["ParentInfo"]</h2>
            </div>
            <div class="page-card-body">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="parentFirstName">@L["FirstName"] <span class="text-danger">*</span></label>
                        <input id="parentFirstName"
                        name="parentFirstName"
                        class="form-control"
                        autocomplete="given-name"
                        @bind="model.Parent.FirstName" />
                        <ValidationMessage For="@(() => model.Parent.FirstName)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="parentLastName">@L["LastName"] <span class="text-danger">*</span></label>
                        <input id="parentLastName"
                        name="parentLastName"
                        class="form-control"
                        autocomplete="family-name"
                        @bind="model.Parent.LastName" />
                        <ValidationMessage For="@(() => model.Parent.LastName)" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="parentPhone">@L["Phone"] <span class="text-danger">*</span></label>
                    <input id="parentPhone"
                    name="parentPhone"
                    class="form-control"
                    autocomplete="tel"
                    inputmode="tel"
                    @bind="model.Parent.Phone" />
                    <ValidationMessage For="@(() => model.Parent.Phone)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="parentEmail">@L["Email"] <span class="text-danger">*</span></label>
                    <input id="parentEmail"
                    name="parentEmail"
                    type="email"
                    class="form-control"
                    autocomplete="email"
                    inputmode="email"
                    @bind="model.Parent.Email" />
                    <ValidationMessage For="@(() => model.Parent.Email)" />
                </div>

            </div>
        </div>

        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["SiblingInfo"]</h2>
            </div>
            <div class="page-card-body">

                @if (model.Siblings.Count == 0)
                {
                    <p class="text-muted mb-3">@L["NoSiblingsAdded"]</p>
                }

                @for (int i = 0; i < model.Siblings.Count; i++)
                {
                    var index = i;

                    <div class="page-sibling-card">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="text-muted mb-0">@L["Sibling"] @(index + 1)</h6>

                            <button type="button"
                            class="btn btn-outline-danger btn-sm"
                            aria-label="@($"{L["RemoveSibling"]} {index + 1}")"
                            @onclick="() => RemoveSibling(index)">
                                @L["RemoveSibling"]
                            </button>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="siblingFirstName_@index">@L["FirstName"]</label>
                                <input id="siblingFirstName_@index"
                                name="siblingFirstName_@index"
                                class="form-control"
                                autocomplete="given-name"
                                @bind="model.Siblings[index].FirstName" />
                                <ValidationMessage For="@(() => model.Siblings[index].FirstName)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="siblingLastName_@index">@L["LastName"]</label>
                                <input id="siblingLastName_@index"
                                name="siblingLastName_@index"
                                class="form-control"
                                autocomplete="family-name"
                                @bind="model.Siblings[index].LastName" />
                                <ValidationMessage For="@(() => model.Siblings[index].LastName)" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label" for="siblingGender_@index">@L["Gender"]</label>
                                <select id="siblingGender_@index"
                                name="siblingGender_@index"
                                class="form-select"
                                @bind="model.Siblings[index].Gender">
                                    <option value="">@L["Select"]</option>
                                    <option value="Male">@L["Male"]</option>
                                    <option value="Female">@L["Female"]</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label" for="siblingTown_@index">@L["Town"]</label>
                                <input id="siblingTown_@index"
                                name="siblingTown_@index"
                                class="form-control"
                                autocomplete="address-level2"
                                @bind="model.Siblings[index].Town" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label" for="siblingDob_@index">@L["DateOfBirth"]</label>
                                <input id="siblingDob_@index"
                                name="siblingDob_@index"
                                type="date"
                                class="form-control"
                                @bind="model.Siblings[index].DateOfBirth"
                                @bind:format="yyyy-MM-dd" />
                                <ValidationMessage For="@(() => model.Siblings[index].DateOfBirth)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="siblingShirtSize_@index">@L["ChildShirtSize"]</label>
                            <select id="siblingShirtSize_@index"
                            name="siblingShirtSize_@index"
                            class="form-select"
                            @bind="model.Siblings[index].ShirtSize">
                                <option value="">@L["Select"]</option>
                                <option value="ChildXS">@L["ChildXS"]</option>
                                <option value="ChildS">@L["ChildS"]</option>
                                <option value="ChildM">@L["ChildM"]</option>
                                <option value="ChildL">@L["ChildL"]</option>
                            </select>
                            <ValidationMessage For="@(() => model.Siblings[index].ShirtSize)" />
                        </div>
                    </div>
                }

                <button type="button"
                class="btn btn-outline-secondary btn-sm"
                aria-label="@L["AddSibling"]"
                @onclick="AddSibling">
                    @L["AddSibling"]
                </button>
            </div>
        </div>

        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["VolunteerInfo"]</h2>
            </div>
            <div class="page-card-body">
                <p class="text-muted">
                    @L["VolunteerText"]
                </p>

                <div class="form-check mb-3">
                    <input id="volunteerToggle"
                    class="form-check-input"
                    type="checkbox"
                    @bind="model.IsVolunteer"
                    @bind:event="onchange"
                    aria-expanded="@model.IsVolunteer.ToString().ToLowerInvariant()"
                    aria-controls="volunteerDetails" />
                    <label class="form-check-label" for="volunteerToggle">
                        @L["VolunteerQuestion"]
                    </label>
                </div>

                @if (model.IsVolunteer)
                {
                    <div id="volunteerDetails">
                        <div class="mb-3">
                            <label class="form-label" for="volunteerRole">@L["VolunteerRole"] <span class="text-danger">*</span></label>
                            <select id="volunteerRole"
                            name="volunteerRole"
                            class="form-select"
                            @bind="model.Volunteer.Role">
                                <option value="">@L["Select"]</option>
                                <option value="Coach">@L["Coach"]</option>
                                <option value="Referee">@L["Referee"]</option>
                            </select>
                            <ValidationMessage For="@(() => model.Volunteer.Role)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="criminalCheck">@L["CriminalCheck"] <span class="text-danger">*</span></label>
                            <select id="criminalCheck"
                            name="criminalCheck"
                            class="form-select"
                            @bind="model.Volunteer.CriminalCheck">
                                <option value="">@L["Select"]</option>
                                <option value="Yes">@L["Yes"]</option>
                                <option value="No">@L["No"]</option>
                            </select>
                            <ValidationMessage For="@(() => model.Volunteer.CriminalCheck)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="volunteerShirtSize">@L["VolunteerShirtSize"] <span class="text-danger">*</span></label>
                            <select id="volunteerShirtSize"
                            name="volunteerShirtSize"
                            class="form-select"
                            @bind="model.Volunteer.ShirtSize">
                                <option value="">@L["Select"]</option>
                                <option value="AdultS">@L["AdultS"]</option>
                                <option value="AdultM">@L["AdultM"]</option>
                                <option value="AdultL">@L["AdultL"]</option>
                                <option value="AdultXL">@L["AdultXL"]</option>
                                <option value="AdultXXL">@L["AdultXXL"]</option>
                            </select>
                            <ValidationMessage For="@(() => model.Volunteer.ShirtSize)" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="page-card mb-4">
            <div class="page-card-header">
                <h2 class="h5 mb-0">@L["WaiverTitle"]</h2>
            </div>
            <div class="page-card-body">

                <p class="text-muted">
                    @L["WaiverIntro"]
                </p>

                <section class="border rounded p-3 mb-3 bg-light" aria-label="@L["WaiverTitle"]">
                    <ol class="mb-3 ps-3" aria-label="@L["WaiverTitle"]">
                        <li class="mb-2">@L["Waiver_Insurance"]</li>
                        <li class="mb-2">@L["Waiver_Volunteers"]</li>
                        <li class="mb-2">@L["Waiver_ParentPresence"]</li>
                        <li class="mb-2">@L["Waiver_Activity"]</li>
                    </ol>

                    <p class="mb-2">@L["Waiver_AuthorizePlay"]</p>
                    <p class="mb-2">@L["Waiver_Release"]</p>

                </section>

                <div class="mb-3">
                    <label class="form-label" for="electronicSignature">
                        @L["ElectronicSignature"] <span class="text-danger">*</span>
                    </label>
                    <input id="electronicSignature"
                    name="electronicSignature"
                    class="form-control"
                    @bind="model.ElectronicSignature"
                    autocomplete="name" />             
                </div>

                <div class="form-check">
                    <input id="waiverAccepted"
                    class="form-check-input"
                    type="checkbox"
                    @bind="model.WaiverAccepted" />
                    <label class="form-check-label" for="waiverAccepted">
                        @L["WaiverCheckbox"] <span class="text-danger">*</span>
                    </label>                
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isSubmitting" aria-busy="@isSubmitting" aria-label="@(isSubmitting ? L["Saving"] : L["Submit"])">
            @if (isSubmitting)
            {
                <span aria-hidden="true">@L["Saving"]</span>
            }
            else
            {
                @L["Submit"]
            }
        </button>
    </EditForm>
}

</div>

@code {
    private bool isSubmitting;
    private bool showMandatoryFieldsWarning;
    private bool registrationCompleted;
    private string? successMessage;
    private string? errorMessage;
    private DateTime? waiverAcceptedOn;
    private List<string> validationErrors = new();

    private RegistrationPageModel model = new();

    private void AddSibling() => model.Siblings.Add(new SiblingInfo());

    private void RegisterAnother()
    {
        registrationCompleted = false;
        successMessage = null;
        errorMessage = null;
        showMandatoryFieldsWarning = false;
        validationErrors.Clear();
        model = new RegistrationPageModel();
        waiverAcceptedOn = null;
    }

    private void RemoveSibling(int index)
    {
        if (index >= 0 && index < model.Siblings.Count)
            model.Siblings.RemoveAt(index);
    }

    private async Task HandleInvalidSubmit()
    {
        showMandatoryFieldsWarning = true;

        var context = new ValidationContext(model);
        context.Items["Localizer"] = L;
        var results = new List<ValidationResult>();
        Validator.TryValidateObject(model, context, results, true);

        validationErrors = results.Select(r => r.ErrorMessage ?? string.Empty).ToList();

        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private async Task Submit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;
            successMessage = null;
            showMandatoryFieldsWarning = false;

            waiverAcceptedOn = DateTime.Now;

            var parent = new Parent
            {
                FirstName = model.Parent.FirstName ?? string.Empty,
                LastName = model.Parent.LastName ?? string.Empty,
                PhoneNumber = model.Parent.Phone,
                Email = model.Parent.Email,
                ElectronicSignature = model.ElectronicSignature,
                WaiverAccepted = model.WaiverAccepted,
                WaiverAcceptedOn = DateTime.Now
            };
            await RegistrationService.CreateParentAsync(parent);

            var newPlayer = new Player
            {
                ParentId = parent.ParentId,
                FirstName = model.Player.FirstName ?? string.Empty,
                LastName = model.Player.LastName ?? string.Empty,
                DateOfBirth = model.Player.DateOfBirth ?? DateTime.Today,
                Gender = model.Player.Gender,
                Town = model.Player.Town,
                ShirtSize = model.Player.ShirtSize
            };

            await RegistrationService.CreatePlayerAsync(newPlayer);

            var activePeriod = await RegistrationService.GetActiveRegistrationPeriodAsync();
            var registration = new Registration
            {
                PlayerId = newPlayer.PlayerId,
                PeriodId = activePeriod?.PeriodId,
                RegisteredAt = DateTime.UtcNow,
                PaymentStatus = "Pending"
            };

            await RegistrationService.CreateRegistrationAsync(registration);

            foreach (var sib in model.Siblings)
            {
                var anyValueEntered =
                    !string.IsNullOrWhiteSpace(sib.FirstName) ||
                    !string.IsNullOrWhiteSpace(sib.LastName) ||
                    !string.IsNullOrWhiteSpace(sib.Gender) ||
                    !string.IsNullOrWhiteSpace(sib.Town) ||
                    sib.DateOfBirth.HasValue ||
                    !string.IsNullOrWhiteSpace(sib.ShirtSize);

                if (!anyValueEntered)
                    continue;

                var sibPlayer = new Player
                {
                    ParentId = parent.ParentId,
                    FirstName = sib.FirstName ?? string.Empty,
                    LastName = sib.LastName ?? string.Empty,
                    DateOfBirth = sib.DateOfBirth ?? DateTime.Today,
                    Gender = sib.Gender,
                    Town = sib.Town,
                    ShirtSize = sib.ShirtSize
                };
                await RegistrationService.CreatePlayerAsync(sibPlayer);

                var sibRegistration = new Registration
                {
                    PlayerId = sibPlayer.PlayerId,
                    PeriodId = activePeriod?.PeriodId,
                    RegisteredAt = DateTime.UtcNow,
                    PaymentStatus = "Pending"
                };
                await RegistrationService.CreateRegistrationAsync(sibRegistration);
            }

            if (model.IsVolunteer)
            {
                var vol = new Volunteer
                {
                    ParentId = parent.ParentId,
                    FirstName = model.Parent.FirstName ?? string.Empty,
                    LastName = model.Parent.LastName ?? string.Empty,
                    Role = model.Volunteer.Role,
                    ShirtSize = model.Volunteer.ShirtSize,
                    CriminalCheckCompleted = model.Volunteer.CriminalCheck == "Yes"
                };
                await RegistrationService.CreateVolunteerAsync(vol);
            }

            successMessage = L["RegistrationComplete"];
            registrationCompleted = true;
            model = new RegistrationPageModel();
            waiverAcceptedOn = null;

            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException?.InnerException?.Message
                ?? ex.InnerException?.Message
                ?? ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class RegistrationPageModel : IValidatableObject
    {
        public PlayerInfo Player { get; set; } = new();
        public ParentInfo Parent { get; set; } = new();
        public VolunteerInfo Volunteer { get; set; } = new();
        public List<SiblingInfo> Siblings { get; set; } = new();

        public string? ElectronicSignature { get; set; }
        public bool WaiverAccepted { get; set; }
        public bool IsVolunteer { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            var localizer = validationContext.Items.ContainsKey("Localizer") 
                ? validationContext.Items["Localizer"] as IStringLocalizer<SharedResource> 
                : null;

            if (string.IsNullOrWhiteSpace(Player.FirstName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_FirstNameRequired"] ?? "First name is required.",
                    new[] { nameof(Player.FirstName) });
            }

            if (string.IsNullOrWhiteSpace(Player.LastName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_LastNameRequired"] ?? "Last name is required.",
                    new[] { nameof(Player.LastName) });
            }

            if (string.IsNullOrWhiteSpace(Player.Gender))
            {
                yield return new ValidationResult(
                    localizer?["Validation_GenderRequired"] ?? "Gender is required.",
                    new[] { nameof(Player.Gender) });
            }

            if (Player.DateOfBirth == null)
            {
                yield return new ValidationResult(
                    localizer?["Validation_DateOfBirthRequired"] ?? "Date of birth is required.",
                    new[] { nameof(Player.DateOfBirth) });
            }

            if (string.IsNullOrWhiteSpace(Player.ShirtSize))
            {
                yield return new ValidationResult(
                    localizer?["Validation_ChildShirtSizeRequired"] ?? "Child shirt size is required.",
                    new[] { nameof(Player.ShirtSize) });
            }

            if (string.IsNullOrWhiteSpace(Parent.FirstName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_FirstNameRequired"] ?? "First name is required.",
                    new[] { nameof(Parent.FirstName) });
            }

            if (string.IsNullOrWhiteSpace(Parent.LastName))
            {
                yield return new ValidationResult(
                    localizer?["Validation_LastNameRequired"] ?? "Last name is required.",
                    new[] { nameof(Parent.LastName) });
            }

            if (string.IsNullOrWhiteSpace(Parent.Phone))
            {
                yield return new ValidationResult(
                    localizer?["Validation_PhoneRequired"] ?? "Phone number is required.",
                    new[] { nameof(Parent.Phone) });
            }

            if (string.IsNullOrWhiteSpace(Parent.Email))
            {
                yield return new ValidationResult(
                    localizer?["Validation_EmailRequired"] ?? "Email is required.",
                    new[] { nameof(Parent.Email) });
            }
            else if (!Parent.Email.Contains("@"))
            {
                yield return new ValidationResult(
                    localizer?["Validation_EmailInvalid"] ?? "Enter a valid email address.",
                    new[] { nameof(Parent.Email) });
            }

            if (string.IsNullOrWhiteSpace(ElectronicSignature))
            {
                yield return new ValidationResult(
                    localizer?["Validation_ElectronicSignatureRequired"] ?? "Electronic signature is required.",
                    new[] { nameof(ElectronicSignature) });
            }

            if (!WaiverAccepted)
            {
                yield return new ValidationResult(
                    localizer?["Validation_WaiverAcceptanceRequired"] ?? "You must accept the waiver to continue.",
                    new[] { nameof(WaiverAccepted) });
            }

            if (IsVolunteer)
            {
                if (string.IsNullOrWhiteSpace(Volunteer.Role))
                {
                    yield return new ValidationResult(
                        localizer?["Validation_VolunteerRoleRequired"] ?? "Volunteer role is required.",
                        new[] { "Volunteer.Role" });
                }

                if (string.IsNullOrWhiteSpace(Volunteer.CriminalCheck))
                {
                    yield return new ValidationResult(
                        localizer?["Validation_CriminalCheckRequired"] ?? "Criminal check selection is required.",
                        new[] { "Volunteer.CriminalCheck" });
                }

                if (string.IsNullOrWhiteSpace(Volunteer.ShirtSize))
                {
                    yield return new ValidationResult(
                        localizer?["Validation_VolunteerShirtSizeRequired"] ?? "Volunteer shirt size is required.",
                        new[] { "Volunteer.ShirtSize" });
                }
            }

            for (int i = 0; i < Siblings.Count; i++)
            {
                var sib = Siblings[i];

                var anyValueEntered =
                    !string.IsNullOrWhiteSpace(sib.FirstName) ||
                    !string.IsNullOrWhiteSpace(sib.LastName) ||
                    !string.IsNullOrWhiteSpace(sib.Gender) ||
                    !string.IsNullOrWhiteSpace(sib.Town) ||
                    sib.DateOfBirth.HasValue ||
                    !string.IsNullOrWhiteSpace(sib.ShirtSize);

                if (anyValueEntered)
                {
                    if (string.IsNullOrWhiteSpace(sib.FirstName))
                    {
                        var sibNum = i + 1;
                        yield return new ValidationResult(
                            string.Format(
                                localizer?["Validation_SiblingFirstNameRequired"] ?? "Sibling {0}: first name is required.",
                                sibNum),
                            new[] { $"Siblings[{i}].FirstName" });
                    }

                    if (string.IsNullOrWhiteSpace(sib.LastName))
                    {
                        var sibNum = i + 1;
                        yield return new ValidationResult(
                            string.Format(
                                localizer?["Validation_SiblingLastNameRequired"] ?? "Sibling {0}: last name is required.",
                                sibNum),
                            new[] { $"Siblings[{i}].LastName" });
                    }

                    if (!sib.DateOfBirth.HasValue)
                    {
                        var sibNum = i + 1;
                        yield return new ValidationResult(
                            string.Format(
                                localizer?["Validation_SiblingDateOfBirthRequired"] ?? "Sibling {0}: date of birth is required.",
                                sibNum),
                            new[] { $"Siblings[{i}].DateOfBirth" });
                    }
                }
            }
        }
    }

    private class PlayerInfo
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Gender { get; set; }
        public string? Town { get; set; }
        public DateTime? DateOfBirth { get; set; }
        public string? ShirtSize { get; set; }
    }

    private class ParentInfo
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
    }

    private class VolunteerInfo
    {
        public string? Role { get; set; }
        public string? CriminalCheck { get; set; }
        public string? ShirtSize { get; set; }
    }

    private class SiblingInfo
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Gender { get; set; }
        public string? Town { get; set; }
        public DateTime? DateOfBirth { get; set; }
        public string? ShirtSize { get; set; }
    }

    private bool registrationOpen;
    private int? seasonYear;

    protected override async Task OnInitializedAsync()
    {
        var activePeriod = await RegistrationService.GetActiveRegistrationPeriodAsync();
        registrationOpen = activePeriod != null;
        seasonYear = activePeriod?.SeasonYear;
    }
}
