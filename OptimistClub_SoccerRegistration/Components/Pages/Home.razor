@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OptimistClub_SoccerRegistration.SharedResource> L

<div class="text-center mb-4">
    <img src="images/Soccer_logo.png" alt="Soccer Optimiste" style="max-width: 150px;" />
    <h1 class="mt-3">@L["HomeTitle"]</h1>
    <p class="lead text-muted">@L["HomeSubtitle"]</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">@L["SeasonInfoTitle"]</div>
            <div class="card-body">
                <p>@L["SeasonInfoBody"]</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@L["PaymentTitle"]</div>
            <div class="card-body">
                <p>@L["PaymentInstructions"]</p>
            </div>
        </div>

        <div class="text-center">
            <a href="/register" class="btn btn-primary btn-lg">@L["RegisterNow"]</a>
        </div>
    </div>
</div>