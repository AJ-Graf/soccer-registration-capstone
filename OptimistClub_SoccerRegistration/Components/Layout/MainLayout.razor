@inherits LayoutComponentBase

<a class="visually-hidden-focusable" href="#main-content">Skip to main content</a>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main id="main-content">
        <div class="top-row px-4 d-flex align-items-center justify-content-end">

            <!-- LANGUAGE TOGGLE (FORCES WASM RESTART) -->
            <nav aria-label="Language selection">
                <div class="d-flex gap-2">
                    <a class="btn btn-sm btn-outline-secondary"
                       href="/Culture/Set?culture=en-CA&redirectUri=/"
                       rel="external"
                       aria-label="Switch to English"
                       lang="en">
                        EN
                    </a>

                    <a class="btn btn-sm btn-outline-secondary"
                       href="/Culture/Set?culture=fr-CA&redirectUri=/"
                       rel="external"
                       aria-label="Passer au français"
                       lang="fr">
                        FR
                    </a>
                </div>
            </nav>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" role="alert" aria-live="assertive">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss" aria-label="Dismiss error">🗙</a>
</div>
