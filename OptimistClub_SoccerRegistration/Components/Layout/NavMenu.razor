
@implements IDisposable
@using Microsoft.Extensions.Localization
@using Microsoft.EntityFrameworkCore
@using OptimistClub_SoccerRegistration.Data
@using OptimistClub_SoccerRegistration.Services
@inject IStringLocalizer<NavMenu> L
@inject NavigationManager NavigationManager
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<div class="top-row navbar navbar-dark">
    <div class="container-fluid px-3">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <img src="images/Soccer_logo.png"
                 alt="Soccer Optimiste"
                 class="nav-logo" />
            <span class="nav-title">Soccer Optimiste</span>
        </a>
    </div>
</div>

<input type="checkbox"
id="navbar-toggler"
title="Navigation menu"
class="navbar-toggler"
aria-label="Toggle navigation menu"
aria-expanded="false"
aria-controls="nav-scrollable" />

<div id="nav-scrollable" class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column nav-menu">

        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
            @L["Home"]
        </NavLink>

        @if (registrationOpen)
        {
            <NavLink class="nav-link" href="register">
                <span class="bi bi-pencil-square-nav-menu" aria-hidden="true"></span>
                @L["RegisterPlayer"]
            </NavLink>

            <NavLink class="nav-link" href="volunteer">
                <span class="bi bi-person-raised-hand-nav-menu" aria-hidden="true"></span>
                @L["RegisterVolunteer"]
            </NavLink>
        }

        <NavLink class="nav-link" href="field-location">
            <span class="bi bi-geo-alt-fill-nav-menu" aria-hidden="true"></span>
            @L["FieldLocation"]
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <div class="nav-divider"></div>

                <NavLink class="nav-link" href="/Account/Manage">
                    <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                    @context.User.Identity?.Name
                </NavLink>        

                <form action="/Account/Logout" method="post" class="px-3">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="nav-link btn-logout">
                        <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span>
                        @L["Logout"]
                    </button>
                </form>
            </Authorized>

            <NotAuthorized>
                <div class="nav-divider"></div>

                <NavLink class="nav-link" href="/Account/Login">
                    <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span>
                    @L["AdminLogin"]
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="bi bi-gear" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/teams">
                    <span class="bi bi-people" aria-hidden="true"></span> Teams
                    <span class="badge bg-info ms-1">@teamCount</span>
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/schedules">
                    <span class="bi bi-calendar" aria-hidden="true"></span> Schedules
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/seasons">
                    <span class="bi bi-clock" aria-hidden="true"></span> Seasons
                    @if (!hasSeasons)
                    {
                        <span class="badge bg-secondary ms-1">N/A</span>
                    }
                    else if (seasonActive)
                    {
                        <span class="badge bg-success ms-1">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger ms-1">Closed</span>
                    }
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/reset">
                    <span class="bi bi-arrow-repeat" aria-hidden="true"></span> Season Reset
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/qrcode">
                    <span class="bi bi-qr-code" aria-hidden="true"></span> QR Code
                </NavLink>
            </div>
        </AuthorizeView>

    </nav>
</div>

@code {
    private string? currentUrl;
    private bool seasonActive;
    private bool registrationOpen;
    private bool hasSeasons;
    private int teamCount;
    private bool dataLoaded;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        await LoadNavDataAsync();
        dataLoaded = true;
    }

    private async Task LoadNavDataAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            hasSeasons = await db.RegistrationPeriods.AnyAsync();
            seasonActive = await db.RegistrationPeriods.AnyAsync(rp => rp.IsActive);

            var today = DateTime.Today;
            registrationOpen = await db.RegistrationPeriods.AnyAsync(rp => rp.IsActive
                && (!rp.RegistrationOpenDate.HasValue || rp.RegistrationOpenDate.Value.Date <= today)
                && (!rp.RegistrationCloseDate.HasValue || rp.RegistrationCloseDate.Value.Date >= today));

            teamCount = await db.Teams.CountAsync();
        }
        catch
        {
            hasSeasons = false;
            seasonActive = false;
            teamCount = 0;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
